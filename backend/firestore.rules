rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /hotZones/{docId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['title', 'location', 'risk', 'createdAt'])
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0;
      // Owner can update editable fields; anyone authed can add a verification
      // or resolution vote to the appropriate lists.
      allow update: if request.auth != null
        && (
          // Community verification (Still hot / Problem fixed)
          request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['verifications', 'verifiedBy', 'resolvedBy'])
          ||
          // Owner editing their own report's content
          (resource.data.userId == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['title', 'description', 'category']))
        );
      // Owner can delete their own report; community takedown when 3+ resolved.
      allow delete: if request.auth != null
        && (
          resource.data.userId == request.auth.uid
          || resource.data.resolvedBy.size() >= 3
        );
    }

    match /coolSpots/{docId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['name', 'type', 'createdAt'])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0;
      allow update: if request.auth != null
        && (
          request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['verifiedBy'])
          ||
          (resource.data.userId == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['name', 'category', 'amenity']))
        );
      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    match /treeEvents/{docId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['title', 'createdAt'])
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0;
      allow update: if request.auth != null
        && (
          request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['rsvpBy', 'waterBy', 'donateBy', 'attendBy'])
          ||
          (resource.data.userId == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['title', 'locationName', 'datePlanted', 'description', 'goalTrees']))
        );
      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // Users can only read and write their own profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
